# Ingest service — local development
#
# Docker Compose uses the repo-root .env instead (see ../../.env.example).
# Copy for local runs: cp .env.example .env
#
# Local dev: replace Docker hostnames with localhost (postgres, redis, minio, qdrant).

# --- Required ---

OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Application (pydantic Settings) ---

APP_NAME=Ingest Service
DEBUG=false
MAX_FILE_SIZE=104857600

# --- Storage ---

STORAGE_PROVIDER=minio
STORAGE_BUCKET=documents
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# --- Database ---

POSTGRES_URL=postgresql://raguser:ragpass@localhost:5432/ragdb

# --- Celery ---

REDIS_URL=redis://localhost:6379/0

# --- Vector DB ---

VECTOR_DB_PROVIDER=pgvector
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION=document_chunks

# QDRANT_RECREATE_ON_DIM_MISMATCH=false
# QDRANT_HNSW_M=0
# QDRANT_HNSW_EF_CONSTRUCT=0
# QDRANT_ENABLE_QUANTIZATION=false
# QDRANT_QUANTIZATION_ALWAYS_RAM=false

# PINECONE_API_KEY=your-pinecone-api-key-here
# PINECONE_INDEX_NAME=your-index-name

# --- Pipeline ---

# Stored vector dimension follows this model (large => 3072, small => 1536).
# All services must use a model of the SAME dimension; changing it requires
# recreating the Qdrant collection and re-ingesting.
INGEST_EMBED_MODEL=text-embedding-3-large
INGEST_CHAPTER_MODEL=gpt-4o-mini
INGEST_CHUNK_SIZE=350
INGEST_CHUNK_OVERLAP=70
INGEST_MAX_CHAPTER_SAMPLE_PAGES=180

# --- Cost tracking (optional) ---

# COST_GPT_4O_MINI_INPUT_PER_M=0.15
# COST_GPT_4O_MINI_OUTPUT_PER_M=0.60
# COST_EMBED_3_LARGE_INPUT_PER_M=0.13
# COST_EMBED_3_SMALL_INPUT_PER_M=0.02
