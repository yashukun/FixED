# Search service — local development
#
# Docker Compose uses the repo-root .env instead (see ../../.env.example).
# Copy for local runs: cp .env.example .env
#
# Local dev: replace Docker hostnames with localhost.

# --- Required (full RAG; guardrails-only queries work without a key) ---

OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Database ---

POSTGRES_URL=postgresql://raguser:ragpass@localhost:5432/ragdb

# --- Vector DB (must match ingest) ---

VECTOR_DB_PROVIDER=pgvector
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION=document_chunks

# --- Models ---

# Must match the dimension of the ingest model (large => 3072, small => 1536).
SEARCH_EMBED_MODEL=text-embedding-3-large
SEARCH_CHAT_MODEL=gpt-4o-mini
SEARCH_INTENT_MODEL=gpt-4o-mini

# --- Retrieval tuning ---

SEARCH_HYBRID_VECTOR_WEIGHT=1.0
SEARCH_QDRANT_GLOBAL_QUERY_EF=64
SEARCH_QDRANT_SCOPED_QUERY_EF=128
SEARCH_GLOBAL_PROBE_TOP_K=24
SEARCH_GLOBAL_ROUTE_CANDIDATE_LIMIT=2

# --- QPaper integration ---

QPAPER_SERVICE_URL=http://localhost:8003
QPAPER_DEFAULT_TOTAL_MARKS=100
QPAPER_DEFAULT_MODE=official

# --- Cost tracking (optional) ---

# COST_GPT_4O_MINI_INPUT_PER_M=0.15
# COST_GPT_4O_MINI_OUTPUT_PER_M=0.60
# COST_EMBED_3_LARGE_INPUT_PER_M=0.13
# COST_EMBED_3_SMALL_INPUT_PER_M=0.02
