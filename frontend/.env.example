# Frontend — Vite environment template
#
# Copy for local dev: cp .env.example .env
#
# Production Docker build uses nginx reverse proxy (frontend/nginx.conf); the
# VITE_*_API defaults below (/api/gateway, /api/ingest, etc.) work without changes.
#
# VITE_*_PROXY_TARGET vars are dev-server only (vite.config.js); ignored in production build.

# --- Runtime API base paths (baked into build) ---

VITE_GATEWAY_API=/api/gateway
VITE_INGEST_API=/api/ingest
VITE_SEARCH_API=/api/search
VITE_QPAPER_API=/api/qpaper
VITE_VIVA_API=/api/viva

# --- Dev server proxy targets (npm run dev only) ---

VITE_GATEWAY_PROXY_TARGET=http://localhost:8000
VITE_INGEST_PROXY_TARGET=http://localhost:8001
VITE_SEARCH_PROXY_TARGET=http://localhost:8002
VITE_QPAPER_PROXY_TARGET=http://localhost:8003
VITE_VIVA_PROXY_TARGET=http://localhost:8004
