# FixED monorepo — environment template
#
# Usage (Docker Compose — recommended):
#   cp .env.example .env
#   # Set OPENAI_API_KEY, then:
#   docker compose up --build
#
# Docker Compose loads this file for: ingest, celery_worker, search, qpaper, viva, gateway.
# REDIS_URL for ingest/celery is overridden in docker-compose.yml (redis://redis:6379/0).
#
# For local service dev (outside Docker), copy the matching service/.env.example and
# use localhost hostnames instead of Docker service names (postgres, redis, minio, etc.).

# =============================================================================
# Required — OpenAI (ingest, search, qpaper, viva)
# =============================================================================

# Required for embeddings, chat, viva voice/vision. Health endpoints work without it.
OPENAI_API_KEY=your-openai-api-key-here

# =============================================================================
# Shared infrastructure
# =============================================================================

# PostgreSQL — Docker default uses hostname "postgres"; local dev uses "localhost"
POSTGRES_URL=postgresql://raguser:ragpass@postgres:5432/ragdb

# Celery broker/result backend — set automatically in Compose for ingest/celery_worker
# Local dev (ingest worker/API outside Docker):
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# Object storage — "minio" locally, "s3" on AWS (IAM task-role credentials).
STORAGE_PROVIDER=minio
STORAGE_BUCKET=documents
# MinIO (local dev only)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
# S3 (when STORAGE_PROVIDER=s3) — credentials come from the IAM task role, not keys.
# AWS_REGION=us-east-1
# S3_ENDPOINT_URL=          # optional: point at MinIO/moto for local S3 testing

# =============================================================================
# Runtime / platform (fail-closed in production)
# =============================================================================

# "development" (default) | "production". In production the app refuses insecure
# default DB/MinIO credentials.
APP_ENV=development

# Structured logging for CloudWatch: "json" (default) | "text"
LOG_FORMAT=json
LOG_LEVEL=INFO

# Comma-separated CORS allowlist (empty = same-origin only, the default behind nginx).
# e.g. CORS_ALLOW_ORIGINS=https://app.example.com
CORS_ALLOW_ORIGINS=

# uvicorn worker processes per container (tune with DB pool sizing below).
UVICORN_WORKERS=2

# Enables the search /debug/retrieval endpoint when true (keep false in prod).
DEBUG=false

# Database connection pool (per process) — tune for RDS max_connections.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800
DB_CONNECT_TIMEOUT=10
# Postgres TLS: "prefer" locally; set "require"/"verify-full" for RDS.
PGSSLMODE=prefer

# OpenAI client hardening (applies to every service).
OPENAI_TIMEOUT=120
OPENAI_MAX_RETRIES=2

# Embedding vector size — MUST match the pgvector column and Qdrant collection.
# Changing it requires a DB migration + full re-embed. text-embedding-3-large is
# truncated to this size via the dimensions= parameter.
EMBEDDING_DIMENSIONS=1536

# Celery worker hardening.
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500
CELERY_RESULT_EXPIRES=86400

# nginx ingress upstreams (frontend image) — Docker DNS locally; ECS Service
# Connect names on AWS (e.g. gateway.fixed.internal:8000).
# UPSTREAM_GATEWAY=gateway:8000
# UPSTREAM_INGEST=ingest:8000
# UPSTREAM_SEARCH=search:8000
# UPSTREAM_QPAPER=qpaper:8000
# UPSTREAM_VIVA=viva:8000

# =============================================================================
# Vector database (ingest + search + qpaper + viva must agree on provider/settings)
# =============================================================================

# pgvector (default, uses POSTGRES_URL) | qdrant | pinecone (ingest only, experimental)
VECTOR_DB_PROVIDER=qdrant
# Qdrant — only when VECTOR_DB_PROVIDER=qdrant
QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION=document_chunks

# Qdrant tuning (ingest) — optional; 0 = use Qdrant defaults
# QDRANT_RECREATE_ON_DIM_MISMATCH=false
# QDRANT_HNSW_M=0
# QDRANT_HNSW_EF_CONSTRUCT=0
# QDRANT_ENABLE_QUANTIZATION=false
# QDRANT_QUANTIZATION_ALWAYS_RAM=false

# Pinecone — only when VECTOR_DB_PROVIDER=pinecone (not used in default Compose stack)
# PINECONE_API_KEY=your-pinecone-api-key-here
# PINECONE_INDEX_NAME=your-index-name

# NOTE: every service now passes dimensions=EMBEDDING_DIMENSIONS (default 1536) on
# every embeddings call, so text-embedding-3-large is safely truncated to 1536 and
# matches the pgvector column / Qdrant collection. To change the size, update
# EMBEDDING_DIMENSIONS (above) AND run a DB migration + re-embed all documents.

# =============================================================================
# Ingest service
# =============================================================================

# Use text-embedding-3-small for 1536-dim compatibility out of the box
INGEST_EMBED_MODEL=text-embedding-3-large
INGEST_CHAPTER_MODEL=gpt-4o-mini
INGEST_CHUNK_SIZE=350
INGEST_CHUNK_OVERLAP=70
INGEST_MAX_CHAPTER_SAMPLE_PAGES=180

# Ingest pydantic settings (also read from env)
# APP_NAME=Ingest Service
# DEBUG=false
# MAX_FILE_SIZE=104857600

# =============================================================================
# Search service
# =============================================================================

SEARCH_EMBED_MODEL=text-embedding-3-large
SEARCH_CHAT_MODEL=gpt-4o-mini
SEARCH_INTENT_MODEL=gpt-4o-mini
SEARCH_HYBRID_VECTOR_WEIGHT=1.0
SEARCH_QDRANT_GLOBAL_QUERY_EF=64
SEARCH_QDRANT_SCOPED_QUERY_EF=128
SEARCH_GLOBAL_PROBE_TOP_K=24
SEARCH_GLOBAL_ROUTE_CANDIDATE_LIMIT=2

# Inter-service URL — Docker hostname; local dev: http://localhost:8003
QPAPER_SERVICE_URL=http://qpaper:8000
QPAPER_DEFAULT_TOTAL_MARKS=100
QPAPER_DEFAULT_MODE=official

# =============================================================================
# QPaper service
# =============================================================================

QPAPER_EMBED_MODEL=text-embedding-3-large
QPAPER_CHAT_MODEL=gpt-4o-mini

# =============================================================================
# Viva service
# =============================================================================

VIVA_CHAT_MODEL=gpt-4o-mini
VIVA_EMBED_MODEL=text-embedding-3-large
VIVA_STT_MODEL=gpt-4o-mini-transcribe
VIVA_TTS_MODEL=gpt-4o-mini-tts
VIVA_VISION_MODEL=gpt-4o-mini
VIVA_RETRIEVAL_TOP_K=20
VIVA_MAX_CONTEXT_CHARS=20000
VIVA_MAX_CHUNK_CHARS=900

VIVA_MIN_QUESTION_COUNT=5
VIVA_MAX_QUESTION_COUNT=10
VIVA_DEFAULT_QUESTION_COUNT=5
VIVA_DEFAULT_PER_QUESTION_LIMIT_SECONDS=60

# Proctoring
VIVA_FACE_MATCH_THRESHOLD=0.9
VIVA_PROCTOR_AMBIGUOUS_CONFIDENCE_MIN=0.65
VIVA_PROCTOR_VIOLATE_ON_AMBIGUOUS=1
VIVA_PROCTOR_MIN_FRAME_INTERVAL_MS=2500
VIVA_PROCTOR_WINDOW_SIZE=8
VIVA_PROCTOR_WINDOW_ANOMALY_THRESHOLD=3
VIVA_PROCTOR_WARNING_MIN_INTERVAL_MS=10000
VIVA_PROCTOR_ACCESSORY_IS_VIOLATION=0
VIVA_PROCTOR_MIN_ANSWERED_QUESTIONS_FOR_WARNING=1

# Follow-ups
VIVA_FOLLOWUP_MIN_RATIO=0.6
# VIVA_MIN_FOLLOWUP_QUESTIONS=

# Media storage (uses MinIO env vars above)
VIVA_MEDIA_BUCKET=viva-media
VIVA_STORE_ALL_FRAMES=0

# =============================================================================
# API cost tracking (optional overrides — USD per 1M tokens)
# =============================================================================

# COST_GPT_4O_MINI_INPUT_PER_M=0.15
# COST_GPT_4O_MINI_OUTPUT_PER_M=0.60
# COST_EMBED_3_LARGE_INPUT_PER_M=0.13
# COST_EMBED_3_SMALL_INPUT_PER_M=0.02
